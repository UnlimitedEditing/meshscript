# card.cnv - a game item card: rounded panel, icon, name, and stats.
# Demonstrates rect(radius=...), nested placement, and multi-field text layout.

doc = new_document(600, 840, background=(18, 20, 26, 255))

panel = rect(560, 800, fill=(40, 44, 56, 255), outline=(120, 110, 60, 255), outline_width=4, radius=24)
doc = align(doc, panel, "center")

# Icon: a glowing hexagon-ish placeholder using a rotated square + circle
icon_bg = ellipse(220, 220, fill=(60, 90, 160, 255))
doc = align(doc, icon_bg, "top", margin=60)

icon_glyph = polygon(
    [(110, 10), (210, 60), (210, 160), (110, 210), (10, 160), (10, 60)],
    fill=(180, 220, 255, 255),
)
doc = place(doc, icon_glyph, doc_size(doc)[0] // 2, 60 + 110, anchor="center")

name = text("Ember Blade", size=52, color=(255, 230, 180, 255), align="center")
doc = align(doc, name, "top", margin=300)

rarity = text("LEGENDARY", size=28, color=(255, 180, 60, 255), align="center")
doc = align(doc, rarity, "top", margin=370)

stats = text(
    "ATK  87\nDEF  12\nSPD  64\n\n"
    "\"Forged in the heart of a dying star,\n"
    "this blade never cools.\"",
    size=30, color=(220, 220, 230, 255), align="center", line_spacing=1.3,
)
doc = align(doc, stats, "bottom", margin=80)

show(doc, "card")
