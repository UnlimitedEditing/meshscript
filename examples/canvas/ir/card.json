{
  "steps": [
    {"var": "doc", "op": "new_document", "args": {"width": 600, "height": 840, "background": [18, 20, 26, 255]}},
    {"var": "panel", "op": "rect", "args": {"w": 560, "h": 800, "fill": [40, 44, 56, 255], "outline": [120, 110, 60, 255], "outline_width": 4, "radius": 24}},
    {"var": "doc", "op": "align", "args": {"doc": {"$ref": "doc"}, "layer": {"$ref": "panel"}, "anchor": "center"}},
    {"var": "icon_bg", "op": "ellipse", "args": {"w": 220, "h": 220, "fill": [60, 90, 160, 255]}},
    {"var": "doc", "op": "align", "args": {"doc": {"$ref": "doc"}, "layer": {"$ref": "icon_bg"}, "anchor": "top", "margin": 60}},
    {"var": "icon_glyph", "op": "polygon", "args": {"points": [[110, 10], [210, 60], [210, 160], [110, 210], [10, 160], [10, 60]], "fill": [180, 220, 255, 255]}},
    {"var": "doc", "op": "place", "args": {"doc": {"$ref": "doc"}, "layer": {"$ref": "icon_glyph"}, "x": 300, "y": 170, "anchor": "center"}},
    {"var": "name", "op": "text", "args": {"content": "Ember Blade", "size": 52, "color": [255, 230, 180, 255], "align": "center"}},
    {"var": "doc", "op": "align", "args": {"doc": {"$ref": "doc"}, "layer": {"$ref": "name"}, "anchor": "top", "margin": 300}},
    {"var": "rarity", "op": "text", "args": {"content": "LEGENDARY", "size": 28, "color": [255, 180, 60, 255], "align": "center"}},
    {"var": "doc", "op": "align", "args": {"doc": {"$ref": "doc"}, "layer": {"$ref": "rarity"}, "anchor": "top", "margin": 370}},
    {"var": "stats", "op": "text", "args": {"content": "ATK  87\nDEF  12\nSPD  64\n\n\"Forged in the heart of a dying star,\nthis blade never cools.\"", "size": 30, "color": [220, 220, 230, 255], "align": "center", "line_spacing": 1.3}},
    {"var": "doc", "op": "align", "args": {"doc": {"$ref": "doc"}, "layer": {"$ref": "stats"}, "anchor": "bottom", "margin": 80}},
    {"var": "_", "op": "show", "args": {"doc": {"$ref": "doc"}, "label": "card"}}
  ]
}
